# Brain OS Configuration

# =============================================
# REQUIRED: Core paths
# =============================================

# Your Obsidian vault path (the vault-template directory)
BRAIN_PATH="{{BRAIN_PATH}}"
# Example: BRAIN_PATH="$HOME/brain"

# Your workspace path (where scripts and prompts live)
WORKSPACE_PATH="{{WORKSPACE_PATH}}"
# Example: WORKSPACE_PATH="$HOME/brain-workspace"

# Your skills directory
SKILLS_PATH="{{SKILLS_PATH}}"
# Example: SKILLS_PATH="$HOME/.agents/skills"

# =============================================
# OPTIONAL: AI Integration
# =============================================

# OpenClaw workspace path (if using OpenClaw for scheduling)
OPENCLAW_WORKSPACE="{{OPENCLAW_WORKSPACE}}"
# Example: OPENCLAW_WORKSPACE="$HOME/.openclaw/workspace"

# QMD semantic/hybrid retrieval (optional; install QMD separately)
# QMD is not bundled with OpenClaw. Set this if qmd is not already on PATH.
# QMD_BIN="/path/to/qmd"
# QMD_BIN_REAL="/path/to/qmd"

# NotebookLM integration (if using notebooklm skill)
# NOTEBOOKLM_API_KEY="{{API_KEY}}"

# =============================================
# OPTIONAL: Notification & Messaging
# =============================================

# Discord webhook for notifications (optional)
# DISCORD_WEBHOOK_URL="{{WEBHOOK_URL}}"

# Discord guild and channel IDs (if using Discord integration)
# DISCORD_GUILD_ID="{{GUILD_ID}}"
# DISCORD_CHANNEL_ID="{{CHANNEL_ID}}"

# =============================================
# OPTIONAL: Nightly Pipeline
# =============================================

# How many days back to process conversations
CONVERSATION_DAYS_BACK=3

# Nightly pipeline log directory
PIPELINE_LOG_DIR="${WORKSPACE_PATH}/logs"

# =============================================
# USER INFO
# =============================================

# Your name (used in AI prompts)
USER_NAME="{{USER_NAME}}"

# Your timezone
TIMEZONE="Asia/Shanghai"
